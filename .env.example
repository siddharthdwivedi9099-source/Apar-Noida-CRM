# ============================================================================
# AI-Native CRM — environment configuration example
# Copy to `.env` for local development and override per environment in your
# deployment platform's secret manager. Values marked [SECRET] MUST be changed
# for any shared or production environment.
# ============================================================================

# ---- Core ----
APP_NAME=ai-native-crm
NODE_ENV=development                 # development | test | production
API_HOST=127.0.0.1                   # use 0.0.0.0 in containers
API_PORT=4000
API_LOG_LEVEL=info                   # fatal|error|warn|info|debug|trace|silent
API_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# ---- Frontend (Vite, inlined at build time) ----
VITE_APP_NAME=AI-Native CRM
VITE_API_BASE_URL=http://127.0.0.1:4000/api/v1
VITE_DEFAULT_THEME=light
VITE_DEFAULT_TENANT_SLUG=sample-tenant

# ---- Networking (host port mappings) ----
WEB_PORT=5173
DOCS_PORT=3001

# ---- Database (PostgreSQL) ----
DATABASE_ENABLED=true
DATABASE_URL=postgresql://crm:crm@localhost:5433/crm   # [SECRET] use managed creds in prod
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm                # [SECRET]

# ---- Default tenant + bootstrap admin (first-run seed) ----
DEFAULT_TENANT_SLUG=sample-tenant
DEFAULT_TENANT_NAME=Sample Tenant
DEFAULT_ADMIN_EMAIL=admin@sample-tenant.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!  # [SECRET] rotate immediately after first login
DEFAULT_ADMIN_FIRST_NAME=Platform
DEFAULT_ADMIN_LAST_NAME=Admin
DEMO_USER_PASSWORD=Demo@1234        # shared only by optional role-based demo users
RUN_MIGRATIONS=false
RUN_SEED=false
RUN_DEMO_SEED=false

# ---- Authentication / sessions ----
JWT_ACCESS_TOKEN_SECRET=dev-access-secret-change-me     # [SECRET] >= 16 chars
JWT_REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me   # [SECRET] >= 16 chars
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_ACCOUNT_LOCK_THRESHOLD=5
AUTH_ACCOUNT_LOCK_MINUTES=30
SESSION_COOKIE_NAME=crm_refresh_token
AUTH_COOKIE_SECURE=false             # set true behind HTTPS in production
AUTH_COOKIE_SAME_SITE=lax            # lax | strict | none

# ---- Security / audit (Phase 27) ----
ENABLE_AUDIT_LOGS=true
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=5000
SECURITY_PROBE_RATE_LIMIT_MAX=5
AUDIT_LOG_RETENTION_DAYS=365
AI_LOG_RETENTION_DAYS=180
EXPORT_LOG_RETENTION_DAYS=365
FILE_UPLOAD_MAX_MB=25

# ---- Observability / performance (Phase 29) ----
SLOW_QUERY_THRESHOLD_MS=500
QUERY_LOGGING_ENABLED=true
METRICS_ENABLED=true
DASHBOARD_CACHE_ENABLED=false        # enable once a Redis runtime is available
DASHBOARD_CACHE_TTL_SECONDS=60
BACKGROUND_WORKERS_ENABLED=false

# ---- Cache / queues (Redis) ----
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6380
REDIS_PORT=6380

# ---- Object storage (S3 / MinIO) ----
S3_ENDPOINT=http://localhost:9002
S3_REGION=local
S3_BUCKET=crm-local
S3_ACCESS_KEY=minioadmin             # [SECRET]
S3_SECRET_KEY=minioadmin             # [SECRET]
S3_API_PORT=9002
S3_CONSOLE_PORT=9003

# ---- AI platform ----
AI_GATEWAY_ENABLED=true
AI_DEFAULT_PROVIDER=anthropic        # openai | anthropic | azure_openai | local
AI_DEFAULT_MODEL=claude-opus-4-8
AI_RATE_LIMIT_PER_MINUTE=60
AI_OPENAI_API_KEY=                   # [SECRET]
AI_ANTHROPIC_API_KEY=                # [SECRET]
AI_AZURE_OPENAI_API_KEY=             # [SECRET]
AI_AZURE_OPENAI_ENDPOINT=
AI_LOCAL_ENDPOINT=
AI_EMBEDDING_MODEL=text-embedding-3-large
AI_VECTOR_BACKEND=placeholder

# ---- Observability tooling (deferred) ----
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

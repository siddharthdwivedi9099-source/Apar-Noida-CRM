# Core
APP_NAME=ai-native-crm
NODE_ENV=development
LOG_LEVEL=info
DEFAULT_TIMEZONE=Asia/Kolkata

# Frontend
VITE_APP_NAME=AI-Native CRM
VITE_API_BASE_URL=http://127.0.0.1:4000/api/v1
VITE_DEFAULT_THEME=light
VITE_DEFAULT_TENANT_SLUG=sample-tenant

# Networking
WEB_PORT=5173
API_PORT=4000
DOCS_PORT=3001
API_HOST=127.0.0.1
API_CORS_ORIGIN=http://127.0.0.1:5173

# API
API_LOG_LEVEL=info

# Multi-tenancy
TENANCY_MODE=logical
DEFAULT_TENANT_SLUG=sample-tenant
DEFAULT_TENANT_NAME=Sample Tenant

# Security
ENABLE_AUDIT_LOGS=true
ENABLE_STRUCTURED_LOGGING=true
SESSION_COOKIE_NAME=crm_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
JWT_ACCESS_TOKEN_SECRET=dev-access-secret-change-me
JWT_REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_ACCOUNT_LOCK_THRESHOLD=5
AUTH_ACCOUNT_LOCK_MINUTES=30

# Configuration
FEATURE_FLAGS_SOURCE=file
CONFIG_SOURCE=file

# Database
DATABASE_URL=postgresql://crm:crm@localhost:5433/crm
DATABASE_ENABLED=true
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
DEFAULT_ADMIN_EMAIL=admin@sample-tenant.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_FIRST_NAME=Platform
DEFAULT_ADMIN_LAST_NAME=Admin

# Cache and queues
REDIS_URL=redis://localhost:6380
REDIS_ENABLED=false
REDIS_PORT=6380

# Object storage
S3_ENDPOINT=http://localhost:9002
S3_REGION=local
S3_BUCKET=crm-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_API_PORT=9002
S3_CONSOLE_PORT=9003

# AI platform
AI_GATEWAY_PROVIDER=unconfigured
AI_DEFAULT_MODEL=
PROMPT_REGISTRY_SOURCE=file
AGENT_REGISTRY_SOURCE=file
RAG_EMBEDDING_MODEL=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Core
APP_NAME=ai-native-crm
NODE_ENV=development
LOG_LEVEL=info
DEFAULT_TIMEZONE=Asia/Kolkata

# Frontend
VITE_APP_NAME=AI-Native CRM
VITE_API_BASE_URL=http://127.0.0.1:4000/api/v1
VITE_DEFAULT_THEME=light

# Networking
WEB_PORT=5173
API_PORT=4000
DOCS_PORT=3001
API_HOST=127.0.0.1
API_CORS_ORIGIN=http://127.0.0.1:5173

# API
API_LOG_LEVEL=info

# Multi-tenancy
TENANCY_MODE=logical
DEFAULT_TENANT_SLUG=sample-tenant

# Security
ENABLE_AUDIT_LOGS=true
ENABLE_STRUCTURED_LOGGING=true
SESSION_COOKIE_NAME=crm_session

# Configuration
FEATURE_FLAGS_SOURCE=file
CONFIG_SOURCE=file

# Database
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm
DATABASE_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm

# Cache and queues
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=crm-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI platform
AI_GATEWAY_PROVIDER=unconfigured
AI_DEFAULT_MODEL=
PROMPT_REGISTRY_SOURCE=file
AGENT_REGISTRY_SOURCE=file
RAG_EMBEDDING_MODEL=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
